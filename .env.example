# Aftersell Skills — Environment Variables
#
# Recommended: add these to ~/.claude/settings.json under the "env" key
# (most reliable with Claude Code's Bash tool — see README for details)
#
# Alternative: export from ~/.zshrc
#
# NEVER commit a .env file with real values to version control.

# LinkedIn account used to browse company people pages and scrape activity
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# Hunter.io API key — used by agency-contact-mapper for email finding/verification
# Get yours at: https://hunter.io/api-keys
HUNTER_API_KEY=your-hunter-io-api-key

# Google Sheet ID for your agency contact/discovery tracking sheet
# The ID is in the sheet URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
AFTERSELL_SHEET_ID=your-google-sheet-id

# Gmail address used to authenticate Google Workspace MCP tool calls
GOOGLE_MCP_EMAIL=your-gmail-address@gmail.com

# Slack incoming webhook URL — used by agency-intel-digest to post digests
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
